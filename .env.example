# ─────────────────────────────────────────────────────────────────────────────
# Cascade — Unified Environment Configuration Template
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────────────────────

# IBM Bob Shell API Key (required for live analysis)
# Get your key from: https://bob.ibm.com/docs/shell/getting-started/install-and-setup
BOBSHELL_API_KEY=your_bob_api_key_here

# Bob Shell timeout (optional, default 15 minutes)
BOB_SHELL_TIMEOUT_MS=900000

# ─────────────────────────────────────────────────────────────────────────────
# Demo Monorepo Configuration (for testing purposes)
# ─────────────────────────────────────────────────────────────────────────────

# Authentication
JWT_SECRET=your-secret-key-here
JWT_EXPIRY=3600

# Email Configuration
SMTP_SERVER=smtp.example.com
SMTP_PORT=587
SMTP_USER=notifications@example.com
SMTP_PASS=your-password-here

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cascade_demo
DB_USER=postgres
DB_PASS=postgres

# Application
NODE_ENV=development
PORT=3000