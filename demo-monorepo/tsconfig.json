{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": "./",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "moduleResolution": "node",
    "baseUrl": ".",
    "paths": {
      "@auth/*": ["services/auth/*"],
      "@billing/*": ["services/billing/*"],
      "@notifications/*": ["services/notifications/*"],
      "@shared/*": ["shared/*"]
    }
  },
  "include": ["services/**/*", "shared/**/*", "tests/**/*"],
  "exclude": ["node_modules", "dist"]
}

